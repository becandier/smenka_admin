# Базовый URL API (с префиксом /api/v1, без хвостового слэша — у бэка redirect_slashes=False)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Домен веб-версии приложения (Flutter web) — используется для сборки HTTPS-ссылки
# приглашения (/invite/{code}) на странице «Инвайт-код». Прод-значение по умолчанию,
# в dev можно переопределить, если веб-версия крутится на другом домене.
VITE_WEB_APP_URL=https://app.smenka.space

# Ключ JS API Яндекс.Карт для карты-пикера на форме рабочих точек (выдаёт владелец).
# Пусто/не задан → карта не подключается, координаты вводятся вручную (форма не падает).
# Для localhost ключ должен иметь домен localhost в списке разрешённых в кабинете Яндекса.
VITE_YANDEX_MAPS_API_KEY=
